layout {

    focus-ring {
        active-color   "#92ccff"
        inactive-color "#111416"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#92ccff"
        inactive-color "#111416"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#92ccff"
        inactive-color "#004b73"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#92ccff80"
    }
}

recent-windows {
    highlight {
        active-color "#92ccff"
        urgent-color "#ffb4ab"
    }
}
